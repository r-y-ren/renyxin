---
import '../styles/globals.css';

interface Props {
  title: string;
  showStarfield?: boolean;
}

const { title, showStarfield = true } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-genshin-dark text-genshin-light">
    {showStarfield && (
      <div class="fixed inset-0 starfield-bg pointer-events-none" aria-hidden="true"></div>
    )}
    <div class="relative z-10">
      <slot />
    </div>
  </body>
</html>

<style is:global>
  :root {
    color-scheme: dark;
  }
  
  html {
    font-family: system-ui, -apple-system, sans-serif;
    letter-spacing: 0.5px;
  }
  
  /* 星空粒子动画 */
  @keyframes twinkle {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 1; }
  }
</style>
