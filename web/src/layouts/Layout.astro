---
/**
 * src/layouts/Layout.astro
 * ──────────────────────────────────────────────────────────────────────────────
 * 全站公共页面外壳（Shell Layout）。
 * 所有页面均通过 <Layout> 包裹，统一提供：
 *   1. HTML 文档结构（head meta / 字符集 / favicon / title）
 *   2. 全局样式注入（src/styles/globals.css）
 *   3. 可选的星空粒子背景（starfield-bg，通过 showStarfield prop 控制）
 *   4. z-index 层叠上下文（星空在 fixed inset-0，内容在 relative z-10）
 *
 * 消费方：
 *   src/pages/index.astro              → showStarfield={false}（关闭星空，使用自己的背景）
 *   src/pages/daily-log/[...slug].astro → 默认 showStarfield=true
 */
import '../styles/globals.css';

/**
 * 组件 Props 接口
 * @prop title       - 页面 <title> 标签内容，搜索引擎和标签栏展示
 * @prop showStarfield - 是否渲染星空粒子背景层，默认为 true
 */
interface Props {
  title: string;
  showStarfield?: boolean;
}

// 解构 props，showStarfield 默认启用
const { title, showStarfield = true } = Astro.props;
---

<!doctype html>
<html lang="zh-CN">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <!-- Favicons：多格式兼容，位于 public/Myfavicon/ -->
    <link rel="icon" type="image/x-icon" href="/Myfavicon/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/Myfavicon/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/Myfavicon/favicon-96x96.png" />
    <link rel="apple-touch-icon" href="/Myfavicon/apple-touch-icon.png" />
    <link rel="manifest" href="/Myfavicon/site.webmanifest" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-genshin-dark text-genshin-light">
    {/* 星空背景层：通过 fixed inset-0 覆盖全屏，pointer-events-none 不拦截点击 */}
    {showStarfield && (
      <div class="fixed inset-0 starfield-bg pointer-events-none" aria-hidden="true"></div>
    )}
    {/* 页面内容层：相对定位 z-10，确保在星空层之上 */}
    <div class="relative z-10">
      <slot />
    </div>

    <!-- 背景音乐 -->
    <audio id="bg-music" src="/music/music1.mp3" loop preload="auto"></audio>
    <!-- 悬浮音乐控制按钮 -->
    <button
      id="music-btn"
      aria-label="切换背景音乐"
      title="点击播放背景音乐"
      class="fixed bottom-6 right-6 z-50 w-12 h-12 rounded-full
             bg-black/40 backdrop-blur-sm border border-genshin-gold/40
             text-genshin-gold hover:bg-genshin-gold/20 hover:border-genshin-gold
             transition-all duration-300 flex items-center justify-center text-xl
             shadow-lg cursor-pointer select-none"
    >
      🔇
    </button>
  </body>
</html>

<script>
  const audio = document.getElementById('bg-music') as HTMLAudioElement;
  const btn = document.getElementById('music-btn') as HTMLButtonElement;

  function updateBtn() {
    const muted = audio.paused;
    btn.textContent = muted ? '🔇' : '🎵';
    btn.title = muted ? '点击播放背景音乐' : '点击暂停背景音乐';
  }

  audio.addEventListener('play', updateBtn);
  audio.addEventListener('pause', updateBtn);

  btn.addEventListener('click', () => {
    if (audio.paused) {
      audio.play().catch(() => {});
    } else {
      audio.pause();
    }
  });

  // 首次用户交互后尝试自动播放
  document.addEventListener('click', () => {
    if (audio.paused) {
      audio.play().catch(() => {});
    }
  }, { once: true });
</script>

<style is:global>
  /* 全局配色方案：强制暗色模式，防止系统亮色模式覆盖 */
  :root {
    color-scheme: dark;
  }
  
  /* 全局字体与字间距基础设置 */
  html {
    font-family: system-ui, -apple-system, sans-serif;
    letter-spacing: 0.5px;
  }
</style>
