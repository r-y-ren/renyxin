我始终认为，技术的终极目的是为了服务于叙事与表达。在浩瀚的 Web 世界中，我们不仅要追求性能的极致，更要寻找那些能触动人心的交互瞬间。就像你现在看到的这段文字，它们并非死板地排列在屏幕上，而是拥有了生命，能够感知到障碍物的存在并主动让出空间。
目前我正持续打磨我的技术栈，深入探索以下领域
`;



const introHtml = marked(introMarkdown);



// 为每个博客文章渲染内容
interface BlogPostWithContent {
  slug: string;
  data: {
    title: string;
    date: Date;
    tags: string[];
    coverImage?: string;
  };
  html: string;
  excerpt: string;
}

const postsWithContent: BlogPostWithContent[] = sortedPosts.map((post) => {
  // 提取 frontmatter 后的 markdown 内容
  const body = post.body.replace(/^---[\s\S]*?---\s*/, '');
  
  // 提取摘要（前 150 个字符）
  const textContent = body
    .replace(/#+\s/g, '') // 移除标题符号
    .replace(/[*_]/g, '') // 移除格式符号
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1') // 提取链接文本
    .trim();
  
  const excerpt = textContent.substring(0, 150) + '...';

  // 使用 marked 将 Markdown 转换为 HTML
  const html = marked(body);
  
  return {
    slug: post.slug,
    data: post.data,
    html,
    excerpt,
  };
});
---

<Layout title="博客列表 - 原神风格">
  <main class="min-h-screen py-20 px-4 relative z-10">
    <div class="max-w-6xl mx-auto">
      <!-- IntroSection: 自我介绍（动态文本环绕） -->
      <section class="mt-20 mb-20">
        <DraggableCharacter
          client:load
          title="旅行者档案"
          imageSrc="/pictures/胡桃.png"
          imageAlt="胡桃立绘"
          markdownHtml={introHtml}
        />
      </section>

      <!-- SkillConstellation: 技能星座 -->
      <section class="mt-20 mb-20">
        <div class="text-center mb-16">
          <h2 class="text-5xl font-bold mb-4">
            <span style="background: linear-gradient(to right, #ece5d8, #b8936d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">技能星座</span>
          </h2>
          <p class="text-genshin-gold text-lg font-light tracking-widest uppercase">
            鼠标悬浮查看 · 点击展开详情
          </p>
          <p class="text-genshin-light/60 text-sm mt-4">
            采用原神命之座风格的可视化技能树
          </p>
        </div>

        <div class="flex justify-center">
          <SkillConstellation client:load skills={skillsData} width={900} height={620} />
        </div>

        {skillsData.length === 0 && (
          <div class="glass-panel text-center py-20 mt-10">
            <p class="text-genshin-light/60 text-xl">
              还没有添加任何技能
            </p>
          </div>
        )}
      </section>

      <!-- BlogGrid: 博客列表 -->
      <section class="mt-20 mb-20">
        <div class="text-center mb-16">
          <h2 class="text-5xl font-bold mb-4">
            <span style="background: linear-gradient(to right, #ece5d8, #b8936d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">博客文章</span>
          </h2>
          <p class="text-genshin-gold text-lg font-light tracking-widest uppercase">
            点击卡片展开阅读完整内容
          </p>
          <p class="text-genshin-light/60 text-sm mt-4">
            共 {blogPosts.length} 篇文章，采用原神风格设计
          </p>
        </div>

        <BlogGrid client:load posts={postsWithContent} />

        {blogPosts.length === 0 && (
          <div class="glass-panel text-center py-20 mt-10">
            <p class="text-genshin-light/60 text-xl">
              还没有发布任何文章
            </p>
          </div>
        )}
      </section>

      <!-- achievements: 成就区块 -->
      <section class="mt-20 mb-20">
        <div class="text-center mb-16">
          <h2 class="text-5xl font-bold mb-4">
            <span style="background: linear-gradient(to right, #ece5d8, #b8936d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">成就系统</span>
          </h2>
          <p class="text-genshin-gold text-lg font-light tracking-widest uppercase">
            可拖拽卡片 · 视差特效 · 毛玻璃风格
          </p>
          <p class="text-genshin-light/60 text-sm mt-4">
            共 {achievements.length} 项成就，体验 Framer Motion 拖拽交互
          </p>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
          {sortedAchievements.map((achievement) => (
            <DraggableCard
              client:load
              title={achievement.data.title}
              subtitle={`分类: ${achievement.data.category}`}
              excerpt={`获得日期: ${achievement.data.date.toLocaleDateString('zh-CN')}`}
              accentLabel={achievement.data.category}
              metadata={[achievement.data.icon || '🏅', achievement.slug]}
            />
          ))}
        </div>

        {achievements.length === 0 && (
          <div class="glass-panel text-center py-20 mt-10">
            <p class="text-genshin-light/60 text-xl">
              还没有添加任何成就
            </p>
          </div>
        )}
      </section>

      <!-- OutlookSection: 未来展望 -->
      <section class="mt-20 mb-20">
        <div class="text-center mb-10">
          <h2 class="text-5xl font-bold mb-4">
            <span style="background: linear-gradient(to right, #ece5d8, #b8936d); -webkit-background-clip: text; -webkit-text-fill-color: transparent; background-clip: text;">关于未来</span>
          </h2>
          <p class="text-genshin-gold text-lg font-light tracking-widest uppercase">
            学习计划 · 职业目标
          </p>
        </div>

        <div class="glass-panel p-6 md:p-8">
          <p class="text-genshin-light/85 leading-8 text-lg">
            未来我会继续深入前端工程化与交互设计，完善组件化体系与性能优化能力，
            同时逐步拓展后端与全栈实践，构建更完整的产品研发视角。
            希望在接下来的项目中，把稳定的技术实现与更有感染力的体验表达结合起来。
          </p>
        </div>
      </section>

      <!-- Footer: 联系方式 -->
      <footer class="mt-20 mb-20 glass-panel px-6 py-8">
        <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4">
          <p class="text-genshin-light/70 text-sm">© 2024 你的名字</p>
          <div class="flex items-center gap-6 text-sm">
            <a href="#" class="text-genshin-gold hover:text-genshin-accent transition-colors">GitHub</a>
            <a href="#" class="text-genshin-gold hover:text-genshin-accent transition-colors">Email</a>
            <a href="#" class="text-genshin-gold hover:text-genshin-accent transition-colors">X / 社交媒体</a>
          </div>
        </div>
      </footer>
    </div>
  </main>
</Layout>

<style>
  /* Prose 样式调整以适应原神主题 */
  :global(.prose) {
    color: inherit;
  }

  :global(.prose h2) {
    @apply font-bold mt-6 mb-3 text-3xl;
    background: linear-gradient(to right, #ece5d8, #b8936d);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  :global(.prose h3) {
    @apply text-genshin-gold font-bold mt-4 mb-2 text-2xl;
  }

  :global(.prose strong) {
    @apply text-genshin-gold font-bold;
  }

  :global(.prose code) {
    @apply bg-genshin-dark/50 text-genshin-accent px-2 py-1 rounded text-sm;
  }

  :global(.prose pre) {
    @apply bg-genshin-dark/50 border border-genshin-gold/20 rounded-lg p-4 overflow-x-auto;
  }

  :global(.prose a) {
    @apply text-genshin-gold hover:text-genshin-accent transition-colors underline;
  }

  :global(.prose ul),
  :global(.prose ol) {
    @apply ml-6 space-y-2;
  }

  :global(.prose li) {
    @apply text-genshin-light/80;
  }

  :global(.prose li::marker) {
    @apply text-genshin-gold;
  }

  :global(.prose blockquote) {
    @apply border-l-4 border-genshin-gold/40 pl-4 italic text-genshin-light/70;
  }
</style>
