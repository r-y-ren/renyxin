---
/**
 * src/pages/index.astro
 * ──────────────────────────────────────────────────────────────────────────────
 * 网站首页（唯一的 SSG 静态入口页面）。
 * 构建时 Astro 执行 frontmatter（--- 之间的代码），从 Content Collections
 * 读取所有数据并渲染为完整 HTML 页面。
 *
 * 整体布局仿照 GitHub Profile 页风格（深色，左侧边栏 + 右侧主内容）：
 *   HEADER  → 顶部固定导航栏（Logo + 面包屑 + 社交链接）
 *   TABBAR  → 导航标签栏（Overview / 博客 / 成就 / 技能）
 *   SIDEBAR → 左侧个人信息栏（头像 / 名字 / 统计 / 技术栈 / 成就 / 链接）
 *   MAIN    → 右侧主内容：
 *               1. README 卡片（DraggableCharacter —— 可拖拽角色 + 文字环绕）
 *               2. 贡献热力图（ContributionGraph）
 *               3. 博客文章网格（BlogGrid）
 *               4. 技能星座图（SkillConstellation）
 *               5. 成就系统（AchievementGrid）
 *               6. 关于未来（DraggableOutlook）
 *   FOOTER  → 版权信息 + 社交链接
 *
 * 数据来源（全部为 src/content/ 本地 Markdown，构建时解析）：
 *   blog         → src/content/blog/*.md
 *   achievements → src/content/achievements/*.md
 *   skills       → src/content/skills/*.md
 *   site-info    → src/content/site-info/{hero,outlook,footer}.md
 *   daily-log    → src/content/daily-log/*.md
 */
import Layout from '../layouts/Layout.astro';
import { getCollection, getEntry } from 'astro:content';
// 交互组件（React Islands，需要 client: 指令激活）
import DraggableCharacter from '../components/DraggableCharacter';
import SkillConstellation from '../components/SkillConstellation';
import ContributionGraph from '../components/ContributionGraph';
import BlogGrid from '../components/BlogGrid';
import AchievementGrid from '../components/AchievementGrid';
import DraggableOutlook from '../components/DraggableOutlook';
// ContributionGraph 的日志条目类型（供 TypeScript 推断）
import type { DailyLogEntry } from '../components/ContributionGraph';
// marked：将 Markdown 字符串转换为 HTML（用于 heroEntry/outlookEntry 正文）
import { marked } from 'marked';

// ── ① 博客文章与成就数据 ─────────────────────────────────────────────────────
// 数据来源：src/content/blog/*.md  |  src/content/achievements/*.md
// getCollection 在构建时从磁盘读取所有条目并按 schema 校验
const blogPosts = await getCollection('blog');
const achievements = await getCollection('achievements');

// 按日期降序排列（最新的在前）
const sortedPosts = blogPosts.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);
const sortedAchievements = achievements.sort((a, b) =>
  new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// ── ② 技能数据（用于侧边栏技术栈列表和技能星座图）────────────────────────────
// 数据来源：src/content/skills/*.md（每个文件一项技能）
// 映射为普通对象数组传给 SkillConstellation 和侧边栏渲染
const skillEntries = await getCollection('skills');
const skillsData = skillEntries.map((e) => ({
  name: e.data.name,
  proficiency: e.data.proficiency,
  class: e.data.class,
  description: e.data.description,
}));

// ── ③ 站点配置（Hero、Outlook、Footer）── ─────────────────────────────────────
// 数据来源：src/content/site-info/*.md，单条查询
//   hero.md    → 页面标题 / 角色立绘路径 / 个人简介（Markdown 正文）
//   outlook.md → "关于未来"卡片文案
//   footer.md  → 版权文字 + 社交链接数组
const heroEntry    = await getEntry('site-info', 'hero');
const outlookEntry = await getEntry('site-info', 'outlook');
const footerEntry  = await getEntry('site-info', 'footer');

// 将 Markdown 正文渲染为 HTML 字符串，传给 Canvas 组件和 DraggableOutlook 组件
const introHtml   = marked.parse(heroEntry!.body) as string;
const outlookHtml = marked.parse(outlookEntry!.body) as string;

// 页脚社交链接列表（footerEntry.data.links 为 {label, href}[] 或 undefined）
const footerLinks     = footerEntry?.data.links ?? [];
// 页脚版权文字，fallback 到 '© 2024'
const footerCopyright = footerEntry?.data.copyright ?? '© 2024';

// ── ④ 每日日志条目（用于 ContributionGraph 热力图）─────────────────────────────
// 数据来源：src/content/daily-log/*.md（文件名 = 日期 = slug）
// 映射为 DailyLogEntry 类型（slug / date / title），供 ContributionGraph 计算格子颜色
const rawLogs = await getCollection('daily-log');
const dailyLogs: DailyLogEntry[] = rawLogs.map((entry) => ({
  slug: entry.slug,
  // 将 Date 对象转为 "YYYY-MM-DD" 字符串，与热力图格子的 dateKey 对齐
  date: (entry.data.date as Date).toISOString().slice(0, 10),
  title: entry.data.title,
}));

// ── ⑤ 博客文章（含渲染后的 HTML 与摘要）─────────────────────────────────────
// BlogGrid 需要完整 HTML 内容用于展开弹窗，以及纯文本摘要用于卡片预览
interface BlogPostWithContent {
  slug: string;
  data: {
    title: string;
    date: Date;
    tags: string[];
    coverImage?: string;
  };
  html: string;    // 由 marked 渲染后的完整 HTML
  excerpt: string; // 前 150 字符的纯文本摘要，末尾加 "..."
}

const postsWithContent: BlogPostWithContent[] = sortedPosts.map((post) => {
  // 剥离 frontmatter（--- ... ---）只保留正文
  const body = post.body.replace(/^---[\s\S]*?---\s*/, '');
  // 提取纯文本：移除 Markdown 标记符，用于生成摘要
  const textContent = body
    .replace(/#+\s/g, '')              // 移除标题井号
    .replace(/[*_]/g, '')             // 移除粗体/斜体符号
    .replace(/\[([^\]]+)\]\([^)]*\)/g, '$1') // 提取链接文字
    .trim();
  const excerpt = textContent.substring(0, 150) + '...';
  // 将完整正文渲染为 HTML，供展开弹窗使用
  const html = marked(body) as string;
  return { slug: post.slug, data: post.data, html, excerpt };
});

// ── ⑥ 成就分列（已计算但当前未在模板中使用，保留供未来布局扩展）─────────────
// 将成就按索引分为三列，用于瀑布流/错列布局
const achCol1 = sortedAchievements.filter((_, i) => i % 3 === 0);
const achCol2 = sortedAchievements.filter((_, i) => i % 3 === 1);
const achCol3 = sortedAchievements.filter((_, i) => i % 3 === 2);
---

<Layout title="Renyxin's digital world" showStarfield={false}>
<div class="gh-root">

  <!-- ╔══════════════════════════════════════════════════════╗ -->
  <!-- ║  HEADER                                              ║ -->
  <!-- ╚══════════════════════════════════════════════════════╝ -->
  <header class="gh-header">
    <div class="gh-header-inner">
      <a class="gh-header-mark" href="/" aria-label="Homepage">
<svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
<path d="M22 12.2039V13.725C22 17.6258 22 19.5763 20.8284 20.7881C19.6569 22 17.7712 22 14 22H10C6.22876 22 4.34315 22 3.17157 20.7881C2 19.5763 2 17.6258 2 13.725V12.2039C2 9.91549 2 8.77128 2.5192 7.82274C3.0384 6.87421 3.98695 6.28551 5.88403 5.10813L7.88403 3.86687C9.88939 2.62229 10.8921 2 12 2C13.1079 2 14.1106 2.62229 16.116 3.86687L18.116 5.10812C20.0131 6.28551 20.9616 6.87421 21.4808 7.82274" stroke="#1C274C" stroke-width="1.5" stroke-linecap="round"/>
<path d="M15 18H9" stroke="#1C274C" stroke-width="1.5" stroke-linecap="round"/>
</svg>
      </a>
      <span class="gh-header-crumb">{heroEntry!.data.title}</span>
      <div class="gh-header-actions">
        {footerLinks.map((link) => (
          <a href={link.href} class="gh-header-link" target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))}
      </div>
    </div>
  </header>

  <!-- ╔══════════════════════════════════════════════════════╗ -->
  <!-- ║  个人资料标签页                                       ║ -->
  <!-- ╚══════════════════════════════════════════════════════╝ -->
  <nav class="gh-tabbar" aria-label="用户资料导航">
    <div class="gh-tabbar-inner">
      <a class="gh-tab is-active" href="#section-overview">
        <svg class="gh-tab-icon" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M8 8a3 3 0 1 0 0-6 3 3 0 0 0 0 6Zm2-3a2 2 0 1 1-4 0 2 2 0 0 1 4 0Zm4 8c0 1-1 1-1 1H3s-1 0-1-1 1-4 6-4 6 3 6 4Zm-1-.004c-.001-.246-.154-.986-.832-1.664C11.516 10.68 10.289 10 8 10c-2.29 0-3.516.68-4.168 1.332-.678.678-.83 1.418-.832 1.664h10Z"/>
        </svg>
        概览
      </a>
      <a class="gh-tab" href="#section-blog">
        <svg class="gh-tab-icon" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/>
        </svg>
        博客文章
        <span class="gh-tab-num">{sortedPosts.length}</span>
      </a>
      <a class="gh-tab" href="#section-achievements">
        <svg class="gh-tab-icon" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
        </svg>
        成就
        <span class="gh-tab-num">{achievements.length}</span>
      </a>
      <a class="gh-tab" href="#section-skills">
        <svg class="gh-tab-icon" viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
          <path d="M11.28 3.22a.75.75 0 0 1 0 1.06l-7.5 7.5a.75.75 0 0 1-1.06-1.06l7.5-7.5a.75.75 0 0 1 1.06 0ZM4.78 3.22a.75.75 0 0 0-1.06 1.06L4.94 5.5 3.72 6.72a.75.75 0 0 0 1.06 1.06l1.5-1.5a.75.75 0 0 0 0-1.06L4.78 3.22Zm6.44 1.06a.75.75 0 0 0-1.06-1.06l-1.5 1.5a.75.75 0 0 0 1.06 1.06l1.5-1.5Z"/>
        </svg>
        技能
        <span class="gh-tab-num">{skillsData.length}</span>
      </a>
    </div>
  </nav>

  <!-- ╔══════════════════════════════════════════════════════╗ -->
  <!-- ║  BODY: SIDEBAR + MAIN                                ║ -->
  <!-- ╚══════════════════════════════════════════════════════╝ -->
  <div class="gh-body">
    <div class="gh-layout">

      <!-- ── SIDEBAR ─────────────────────────────────────── -->
      <aside class="gh-sidebar">

        <!-- Avatar (角色头像，肖像比例相框) -->
        <!-- ??表达式，当左侧表达式的值是 null 或 undefined 时，返回右侧的默认值；否则返回左侧的值。 -->
         <!-- 没有给路径时，使用默认头像 -->
        <div class="gh-avatar-wrap" >
          <img
            src={heroEntry!.data.avatarImage ?? heroEntry!.data.characterImage ?? '/pictures/avatar.jpg'}
            alt={heroEntry!.data.avatarAlt ?? '头像'}
            class="gh-avatar"
            
          />
        </div>

        <!-- Identity -->
        <h1 class="gh-display-name">{heroEntry!.data.title}</h1>
        <p class="gh-handle">{heroEntry!.data.subtitle ?? '努力学习，好好吃饭の二次元~'}</p>

        <!-- Follow button -->
        <button class="gh-btn-follow" type="button" >
          <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" aria-hidden="true">
            <path d="M8 9a3 3 0 1 0 0-6 3 3 0 0 0 0 6ZM8 10a6 6 0 0 0-6 6h12a6 6 0 0 0-6-6Z"/>
          </svg><a href="https://github.com/r-y-ren">
          关注</a>
        </button>

        <!-- Stats -->
        <div class="gh-stats-row">
          <span class="gh-stat">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-stat-icon" aria-hidden="true">
              <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/>
            </svg>
            <strong>{sortedPosts.length}</strong>
            <span class="gh-stat-label">篇文章</span>
          </span>
          <span class="gh-stat-sep">·</span>
          <span class="gh-stat">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-stat-icon" aria-hidden="true">
              <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
            </svg>
            <strong>{achievements.length}</strong>
            <span class="gh-stat-label">成就</span>
          </span>
        </div>

        <div class="gh-divider"></div>

        <!-- Tech stack / Language list -->
        <div class="gh-sidebar-block">
          <h3 class="gh-sidebar-label">技术栈</h3>
          <div class="gh-lang-list">
            {skillsData.map((s) => {
              const color =
                s.class === 'frontend'  ? '#d4a853' :
                s.class === 'backend'   ? '#58a6ff' :
                s.class === 'runtime'   ? '#3fb950' :
                s.class === 'framework' ? '#bc8cff' :
                s.class === 'style'     ? '#f6748f' :
                '#8b949e';
              return (
                <div class="gh-lang-row">
                  <span class="gh-lang-dot" style={`background:${color}`}></span>
                  <span class="gh-lang-name">{s.name}</span>
                  <span class="gh-lang-pct">{s.proficiency}%</span>
                </div>
              );
            })}
          </div>
        </div>

        <div class="gh-divider"></div>

        <!-- Compact achievement badges -->
        <div class="gh-sidebar-block">
          <h3 class="gh-sidebar-label">
            成就徽章
            <span class="gh-sidebar-count">{achievements.length}</span>
          </h3>
          <div class="gh-ach-compact">
            {sortedAchievements.slice(0, 6).map((a) => (
              <div class="gh-ach-badge" title={`${a.data.title} · ${a.data.category}`}>
                <div class="gh-ach-icon">{a.data.icon ?? '🏅'}</div>
                <div class="gh-ach-meta">
                  <span class="gh-ach-name">{a.data.title}</span>
                  <span class="gh-ach-cat">{a.data.category}</span>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div class="gh-divider"></div>

        <!-- External links -->
        <div class="gh-sidebar-block">
          {footerLinks.map((link) => (
            <a href={link.href} class="gh-sidebar-link" target="_blank" rel="noopener noreferrer">
              <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-sidebar-link-icon" aria-hidden="true">
                <path d="m7.775 3.275 1.25-1.25a3.5 3.5 0 1 1 4.95 4.95l-2.5 2.5a3.5 3.5 0 0 1-4.95 0 .751.751 0 0 1 .018-1.042.751.751 0 0 1 1.042-.018 1.998 1.998 0 0 0 2.83 0l2.5-2.5a2.002 2.002 0 0 0-2.83-2.83l-1.25 1.25a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042Zm-4.69 9.64a1.998 1.998 0 0 0 2.83 0l1.25-1.25a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042l-1.25 1.25a3.5 3.5 0 0 1-4.95-4.95l2.5-2.5a3.5 3.5 0 0 1 4.95 0 .751.751 0 0 1-.018 1.042.751.751 0 0 1-1.042.018 1.998 1.998 0 0 0-2.83 0l-2.5 2.5a1.998 1.998 0 0 0 0 2.83Z"/>
              </svg>
              {link.label}
            </a>
          ))}
        </div>

      </aside>

      <!-- ── MAIN CONTENT ──────────────────────────────────── -->
      <main class="gh-main">

        <!-- 1. Profile README (DraggableCharacter as interactive profile card) -->
        <div class="gh-card" id="section-overview">
          <div class="gh-card-header">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-card-icon" aria-hidden="true">
              <path d="M0 1.75A.75.75 0 0 1 .75 1h4.253c1.227 0 2.317.59 3 1.501A3.743 3.743 0 0 1 11.006 1h4.245a.75.75 0 0 1 .75.75v10.5a.75.75 0 0 1-.75.75h-4.507a2.25 2.25 0 0 0-1.591.659l-.622.621a.75.75 0 0 1-1.06 0l-.622-.621A2.25 2.25 0 0 0 5.258 13H.75a.75.75 0 0 1-.75-.75Zm7.251 10.324.004-5.073-.002-2.253A2.25 2.25 0 0 0 5.003 2.5H1.5v9h3.757a3.75 3.75 0 0 1 1.994.574ZM8.755 4.75l-.004 7.322a3.752 3.752 0 0 1 1.992-.572H14.5v-9h-3.495a2.25 2.25 0 0 0-2.25 2.25Z"/>
            </svg>
            <span class="gh-card-title">
              <span class="gh-muted">{heroEntry!.data.title}</span>
              <span class="gh-muted mx-1">/</span>
              <strong class="gh-text">Experience</strong>
              <span class="gh-muted">.md</span>
            </span>
            <span class="gh-pin-badge ml-auto">Pinned</span>
          </div>
          <div class="gh-readme-body">
            <DraggableCharacter
              client:load
              title={heroEntry!.data.title}
              imageSrc={heroEntry!.data.characterImage ?? '/pictures/胡桃.png'}
              imageAlt={'立绘'}
              markdownHtml={introHtml}
            />
          </div>
        </div>

        <!-- 2. Contribution Graph -->
        <div class="gh-card">
          <div class="gh-card-header">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-card-icon" aria-hidden="true">
              <path d="M1.5 1.75V13.5h13.75a.75.75 0 0 1 0 1.5H.75a.75.75 0 0 1-.75-.75V1.75a.75.75 0 0 1 1.5 0Zm14.28 2.53-5.25 5.25a.75.75 0 0 1-1.06 0L7 7.06 4.28 9.78a.751.751 0 0 1-1.042-.018.751.751 0 0 1-.018-1.042l3.25-3.25a.75.75 0 0 1 1.06 0L10 7.94l4.72-4.72a.751.751 0 0 1 1.042.018.751.751 0 0 1 .018 1.042Z"/>
            </svg>
            <span class="gh-text font-semibold text-sm">{dailyLogs.length} 条日志记录 · 过去一年</span>
            <span class="gh-muted text-xs ml-auto">每日进程</span>
          </div>
          <div class="gh-card-body gh-contrib-wrap">
            <ContributionGraph client:load logs={dailyLogs} />
          </div>
        </div>

        <!-- 3. Blog Posts -->
        <div id="section-blog">
          <div class="gh-section-row">
            <h2 class="gh-section-title">
              <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-section-icon" aria-hidden="true">
                <path d="M2 2.5A2.5 2.5 0 0 1 4.5 0h8.75a.75.75 0 0 1 .75.75v12.5a.75.75 0 0 1-.75.75h-2.5a.75.75 0 0 1 0-1.5h1.75v-2h-8a1 1 0 0 0-.714 1.7.75.75 0 1 1-1.072 1.05A2.495 2.495 0 0 1 2 11.5Zm10.5-1h-8a1 1 0 0 0-1 1v6.708A2.486 2.486 0 0 1 4.5 9h8Z"/>
              </svg>
              博客文章
              <span class="gh-count-badge">{sortedPosts.length}</span>
            </h2>
          </div>
          <div class="gh-blog-wrap mt-3">
            <BlogGrid client:load posts={postsWithContent} />
          </div>
        </div>

        <!-- 4. Skill Constellation -->
        <div class="gh-card" id="section-skills">
          <div class="gh-card-header">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-card-icon" aria-hidden="true">
              <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
            </svg>
            <span class="gh-text font-semibold text-sm">技能星座</span>
            <span class="gh-muted text-xs ml-auto">悬浮查看 · 点击展开</span>
          </div>
          <div class="gh-card-body flex justify-center overflow-x-auto">
            <SkillConstellation client:load skills={skillsData} width={760} height={480} />
          </div>
        </div>

        <!-- 5. Achievement grid (GitHub achievement badge style) -->
        <div id="section-achievements">
          <div class="gh-section-row">
            <h2 class="gh-section-title">
              <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-section-icon" aria-hidden="true">
                <path d="M8 .25a.75.75 0 0 1 .673.418l1.882 3.815 4.21.612a.75.75 0 0 1 .416 1.279l-3.046 2.97.719 4.192a.751.751 0 0 1-1.088.791L8 12.347l-3.766 1.98a.75.75 0 0 1-1.088-.79l.72-4.194L.818 6.374a.75.75 0 0 1 .416-1.28l4.21-.611L7.327.668A.75.75 0 0 1 8 .25Z"/>
              </svg>
              成就系统
              <span class="gh-count-badge">{achievements.length}</span>
            </h2>
          </div>
          <div class="mt-3">
            <AchievementGrid
              client:load
              achievements={sortedAchievements.map((a) => ({
                slug: a.slug,
                data: a.data,
                body: a.body ?? '',
              }))}
            />
          </div>
        </div>

        <!-- 6. Outlook -->
        <div class="gh-card">
          <div class="gh-card-header">
            <svg viewBox="0 0 16 16" width="16" height="16" fill="currentColor" class="gh-card-icon" aria-hidden="true">
              <path d="M0 1.75C0 .784.784 0 1.75 0h12.5C15.216 0 16 .784 16 1.75v9.5A1.75 1.75 0 0 1 14.25 13H8.06l-2.573 2.573A1.458 1.458 0 0 1 3 14.543V13H1.75A1.75 1.75 0 0 1 0 11.25Zm1.75-.25a.25.25 0 0 0-.25.25v9.5c0 .138.112.25.25.25h2a.75.75 0 0 1 .75.75v2.19l2.72-2.72a.749.749 0 0 1 .53-.22h6.5a.25.25 0 0 0 .25-.25v-9.5a.25.25 0 0 0-.25-.25Z"/>
            </svg>
            <span class="gh-text font-semibold text-sm">{outlookEntry!.data.title}</span>
            <span class="gh-muted text-xs ml-2">{outlookEntry!.data.subtitle}</span>
          </div>
          <div class="gh-card-body">
            <DraggableOutlook
              client:load
              title={outlookEntry!.data.title}
              subtitle={outlookEntry!.data.subtitle}
              htmlContent={outlookHtml}
            />
          </div>
        </div>

      </main><!-- /gh-main -->
    </div><!-- /gh-layout -->
  </div><!-- /gh-body -->

  <!-- ╔══════════════════════════════════════════════════════╗ -->
  <!-- ║  FOOTER                                              ║ -->
  <!-- ╚══════════════════════════════════════════════════════╝ -->
  <footer class="gh-footer">
    <div class="gh-footer-inner">
      <span>{footerCopyright}</span>
      <nav class="gh-footer-nav">
        {footerLinks.map((link) => (
          <a href={link.href} class="gh-footer-link" target="_blank" rel="noopener noreferrer">
            {link.label}
          </a>
        ))}
      </nav>
    </div>
  </footer>

</div>
</Layout>

<style>
  /* ═══ GitHub Dark Palette ══════════════════════════════════════════ */
